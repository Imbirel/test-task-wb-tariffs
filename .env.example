# --- Application (General) ---
NODE_ENV=production
TZ=Europe/Moscow
APP_PORT=5000

# --- Logging ---
LOG_LEVEL=info
LOG_FILE_PATH=./logs/app.log

# --- Database (PostgreSQL) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# --- Wildberries API ---
WB_API_URL=https://common-api.wildberries.ru/api/v1/tariffs/box
WB_API_TOKEN=

# --- Google API (Service Account) ---
GOOGLE_AUTH_URL=https://www.googleapis.com/auth/spreadsheets
# значение client_email из json
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# значение private_key из json
GOOGLE_PRIVATE_KEY=
# IDs Google-таблиц через запятую
GOOGLE_SHEET_IDS=

# --- Scheduler ---
CRON_SCHEDULE=0 * * * *
